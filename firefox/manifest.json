{
  "manifest_version": 2,
  "name": "Tab Sorter",
  "version": "1.1",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "browser_action": {
    "default_title": "Click to organize tabs by hostname."
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "tabs",
    "tabGroups"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "sortabasaurus@mitchellamihod",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "allowed": false,
        "required": ["none"]
      }
    }
  }
}
